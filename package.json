{
  "name": "helpdesk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "catalog": {
    "elysia": "latest",
    "@elysiajs/cors": "latest",
    "@types/bun": "latest"
  },
  "catalogs": {},
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:backend": "bun run --filter backend dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '@helpdesk/backend' typecheck",
    "db:push": "bun run --filter '@helpdesk/backend' db:push",
    "db:generate": "bun run --filter '@helpdesk/backend' db:generate",
    "db:migrate": "bun run --filter '@helpdesk/backend' db:migrate",
    "db:studio": "bun run --filter '@helpdesk/backend' db:studio",
    "seed": "bun run --filter '@helpdesk/backend' seed",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}